@{
    ViewData["Title"] = "Lucky Draw Registration";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">

    <div class="card shadow p-4">

        <h3 class="text-center mb-4">Wealthline Infrastructure Lucky Draw</h3>

        <form id="drawForm">

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label class="form-label">Full Name</label>
                    <input id="FullName" class="form-control" required />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Mobile</label>
                    <input id="Mobile"
                           maxlength="10"
                           class="form-control"
                           oninput="this.value=this.value.replace(/[^0-9]/g,'')"
                           required />
                </div>

            </div>

            <div class="mb-3">
                <label class="form-label">Address</label>
                <textarea id="Address" class="form-control" required></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label">Aadhaar Number</label>
                <input id="AadhaarNumber"
                       maxlength="12"
                       class="form-control"
                       oninput="this.value=this.value.replace(/[^0-9]/g,'')"
                       required />
            </div>

            <!-- Prize Selection -->

            <div class="mb-3">
                <label class="form-label">Select Prize</label>

                <select id="PrizeChoice" class="form-select prize-dropdown" required>

                    <option value="">Select Prize</option>
                    <option value="1000 Sqft Plot">1000 Sqft Plot</option>
                    <option value="LCD TV">LCD TV</option>
                    <option value="10gm Silver Coin">10gm Silver Coin</option>

                </select>
            </div>

            <div class="text-center">

                <button id="payButton" class="btn btn-warning btn-lg">
                    Pay ₹@ViewBag.EntryAmount
                </button>

            </div>

        </form>

    </div>

</div>


<!-- SUCCESS MODAL -->

<div class="modal fade" id="successModal">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">Payment Successful</h5>
            </div>

            <div class="modal-body text-center">

                <h5>Your Lucky Draw Entry is Confirmed</h5>

                <p class="mt-3">
                    Card Number :
                    <strong id="cardNumber"></strong>
                </p>

                <p>Please download your receipt for future reference.</p>

            </div>

            <div class="modal-footer">

                <a id="downloadBtn" class="btn btn-primary">
                    Download Receipt
                </a>

            </div>

        </div>

    </div>

</div>


<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>


<script>

    document.getElementById("payButton").onclick = function(e){

    e.preventDefault();

    let name = FullName.value.trim();
    let mobile = Mobile.value.trim();
    let aadhaar = AadhaarNumber.value.trim();
    let prize = PrizeChoice.value;

    let mobileRegex = /^[6-9][0-9]{9}$/;
    let aadhaarRegex = /^[0-9]{12}$/;

    if(name === ""){
    alert("Please enter full name");
    return;
    }

    if(!mobileRegex.test(mobile)){
    alert("Invalid mobile number");
    return;
    }

    if(!aadhaarRegex.test(aadhaar)){
    alert("Invalid Aadhaar number");
    return;
    }

    if(prize === ""){
    alert("Please select prize");
    return;
    }

    let entry = {
    FullName:name,
    MobileNumber:mobile,
    Address:Address.value,
    AadhaarNumber:aadhaar,
    PrizeChoice:prize
    };

    document.getElementById("payButton").disabled = true;

    fetch("/LuckyDraw/CreateOrder",{method:"POST"})
    .then(r=>r.json())
    .then(data=>{

    let options = {

    key:"@ViewBag.RazorKey",

    amount:data.amount*100,

    currency:"INR",

    name:"Wealthline Infrastructure",

    description:"Lucky Draw Entry",

    order_id:data.orderId,

    prefill:{
    name:name,
    contact:mobile
    },

    handler:function(response){

    fetch("/LuckyDraw/VerifyPayment",{

    method:"POST",

    headers:{"Content-Type":"application/json"},

    body:JSON.stringify({

    entry:entry,

    razorpay_payment_id:response.razorpay_payment_id,

    razorpay_order_id:response.razorpay_order_id,

    razorpay_signature:response.razorpay_signature

    })

    })

    .then(r=>r.json())

    .then(result=>{

    if(result.success){

    document.getElementById("cardNumber").innerText=result.card;

    document.getElementById("downloadBtn").href =
    "/LuckyDraw/DownloadReceipt?card="+result.card;

    new bootstrap.Modal(
    document.getElementById("successModal")
    ).show();

    }else{

    alert(result.message);
    document.getElementById("payButton").disabled=false;

    }

    });

    }

    };

    new Razorpay(options).open();

    });

    };


    document.getElementById("downloadBtn").addEventListener("click",function(){

    const modalElement=document.getElementById("successModal");
    const modal=bootstrap.Modal.getInstance(modalElement);

    if(modal){
    modal.hide();
    }

    });

</script>