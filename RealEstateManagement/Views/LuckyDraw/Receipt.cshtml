@model RealEstateManagement.Models.LuckyDrawEntry

<div class="container mt-5">

    <div class="card p-4 shadow">

        <h3>Lucky Draw Receipt</h3>

        <hr />

        <p><strong>Name:</strong> @Model.FullName</p>
        <p><strong>Mobile:</strong> @Model.MobileNumber</p>
        <p><strong>Card Number:</strong> @Model.CardNumber</p>
        <p><strong>Prize:</strong> @Model.PrizeChoice</p>
        <p><strong>Date:</strong> @Model.EntryDate</p>

    </div>

</div>