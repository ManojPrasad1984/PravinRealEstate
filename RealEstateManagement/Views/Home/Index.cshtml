@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- HERO -->

<section class="hero-section">

    <div class="container text-center">

        <h1 class="hero-title">
            Invest in Premium Plots in Nagpur
        </h1>

        <p class="hero-subtitle">
            Wealthline Infrastructure – Creating Wealth for Your Future
        </p>

        <a class="btn btn-scheme btn-lg mt-3" href="/LuckyDraw/Apply">
            Join ₹1100 Lucky Draw Scheme
        </a>

    </div>

</section>



<!-- SCHEME HIGHLIGHT -->

<section class="scheme-section">

    <div class="container">

        <div class="row align-items-center">

            <div class="col-lg-6">

                <img src="/image/scheme.jpeg" class="img-fluid shadow">

            </div>

            <div class="col-lg-6">

                <h2 class="scheme-title">

                    Lucky Draw Investment Scheme

                </h2>

                <p>

                    Participate in Wealthline Infrastructure lucky draw scheme.

                    Entry only ₹1100.

                    Chance to win:

                </p>

                <ul class="scheme-list">

                    <li>1000 Sqft Plot</li>

                    <li>LCD TV</li>

                    <li>10 Gram Silver Coin</li>

                </ul>

                <h3 class="scheme-price">

                    Entry ₹1100

                </h3>

                <a class="btn btn-primary btn-lg" href="/LuckyDraw/Apply">

                    Join Scheme

                </a>

            </div>

        </div>

    </div>

</section>



<!-- PROJECT LAYOUT -->

<section class="layout-section">

    <div class="container">

        <h2 class="section-title">

            Project Layout

        </h2>

        <img src="/image/layout.jpeg" class="img-fluid shadow rounded">

    </div>

</section>



<!-- TERMS -->

<section class="terms-section">

    <div class="container">

        <h2 class="section-title">

            Terms & Conditions

        </h2>

        <img src="/image/conditions.jpeg" class="img-fluid">

    </div>

</section>



<!-- CONTACT -->

<section class="contact-section">

    <div class="container text-center">

        <h2>

            Contact for Booking

        </h2>

        <h3>

            Pravin

        </h3>

        <p>

            +91 7843045164

        </p>

        <a class="btn btn-scheme btn-lg">

            Call Now

        </a>

    </div>

</section>